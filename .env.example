# Google AI Studio key — used for BOTH the Gemini chat model (driven through the
# OpenAI Agents SDK) and Gemini embeddings. Free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_google_ai_studio_api_key_here

# Gemini's OpenAI-compatible endpoint. The OpenAI Agents SDK talks to this URL.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Models (optional overrides)
CHAT_MODEL=gemini-2.5-flash
EMBED_MODEL=gemini-embedding-001

# Where ChromaDB stores its data. Defaults to a local persistent dir if a server
# URL is not reachable. To use a running Chroma server, set CHROMA_URL instead.
# CHROMA_URL=http://localhost:8000

# Server port
PORT=3000
